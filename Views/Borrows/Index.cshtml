@model List<LibraryManagementSystem.Models.BorrowRecord>
@{
    ViewData["Title"] = "Borrow Records";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-arrow-left-right me-2"></i>Borrow Records</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Issue Book
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control form-control-sm" placeholder="Search by student or book..." />
            <button class="btn btn-outline-primary btn-sm px-3" type="submit">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th class="ps-3">#</th>
                    <th>Student</th>
                    <th>Book</th>
                    <th>Borrowed</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="ps-3">@r.Id</td>
                        <td>@r.User.FullName</td>
                        <td class="fw-semibold">@r.Book.Title</td>
                        <td class="small text-muted">@r.BorrowedAt.ToString("MMM dd, yyyy")</td>
                        <td class="small">@r.DueDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (r.IsReturned)
                            {
                                <span class="badge bg-success">Returned</span>
                            }
                            else if (r.DueDate < DateTime.Now)
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Borrowed</span>
                            }
                        </td>
                        <td>
                            @if (!r.IsReturned)
                            {
                                <a asp-action="Return" asp-route-id="@r.Id"
                                   class="btn btn-success btn-sm">
                                    <i class="bi bi-check-lg me-1"></i>Return
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">@r.ReturnedAt?.ToString("MMM dd")</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No borrow records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>