@page "/Users"
@model LibraryManagementSystem.Pages.Users.IndexModel
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2"></i>User Management</h4>
    @if (Model.ShowInactive)
    {
        <a href="/Users" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-eye me-1"></i>Active Only
        </a>
    }
    else
    {
        <a href="/Users?showInactive=true" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-eye-slash me-1"></i>Show Deactivated
        </a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="hidden" name="showInactive"
                   value="@Model.ShowInactive.ToString().ToLower()" />
            <input type="text" name="search" value="@Model.Search"
                   class="form-control form-control-sm"
                   placeholder="Search by name or email..." />
            <button class="btn btn-outline-primary btn-sm px-3" type="submit">Search</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a href="/Users" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th class="ps-3">#</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Registered</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr class="@(!user.IsActive ? "table-secondary text-muted" : "")">
                        <td class="ps-3">@user.Id</td>
                        <td class="fw-semibold">@user.FullName</td>
                        <td class="text-muted small">@user.Email</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else if (user.Role == "Librarian")
                            {
                                <span class="badge bg-primary">Librarian</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Student</span>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="small text-muted">
                            @user.CreatedAt.ToString("MMM dd, yyyy")
                        </td>
                        <td>
                            @if (user.Email != "admin@libman.com")
                            {
                                @if (user.IsActive)
                                {
                                    <a href="/Users/Edit/@user.Id"
                                       class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/Users/Deactivate/@user.Id"
                                       class="btn btn-danger btn-sm">
                                        <i class="bi bi-slash-circle"></i>
                                    </a>
                                }
                                else
                                {
                                    <a href="/Users/Restore/@user.Id"
                                       class="btn btn-success btn-sm">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </a>
                                }
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Users.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No users found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>