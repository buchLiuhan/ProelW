@page
@model LibraryManagementSystem.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (User.IsInRole("Student"))
{
    <!-- STUDENT DASHBOARD -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-book fs-3 text-primary"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Books</div>
                        <div class="fs-3 fw-bold">@Model.TotalBooks</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-bookmark-check fs-3 text-warning"></i>
                    </div>
                    <div>
                        <div class="text-muted small">My Active Borrows</div>
                        <div class="fs-3 fw-bold">@Model.MyActiveBorrows</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-exclamation-triangle fs-3 text-danger"></i>
                    </div>
                    <div>
                        <div class="text-muted small">My Overdue</div>
                        <div class="fs-3 fw-bold">@Model.MyOverdue</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 fw-semibold pt-3">
            <i class="bi bi-bookmark-check text-primary"></i> My Borrowed Books
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Book</th>
                        <th>Borrowed</th>
                        <th>Due Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.MyBorrows)
                    {
                        <tr>
                            <td class="fw-semibold">@b.Book.Title</td>
                            <td class="small text-muted">@b.BorrowedAt.ToString("MMM dd, yyyy")</td>
                            <td class="small @(b.DueDate < DateTime.Now && !b.IsReturned ? "text-danger fw-semibold" : "")">
                                @b.DueDate.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                @if (b.IsReturned)
                                {
                                    <span class="badge bg-success">Returned</span>
                                }
                                else if (b.DueDate < DateTime.Now)
                                {
                                    <span class="badge bg-danger">Overdue</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Borrowed</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.MyBorrows.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                <i class="bi bi-inbox d-block fs-4 mb-2"></i>
                                You have no borrowed books yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <!-- ADMIN / LIBRARIAN DASHBOARD -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-book fs-3 text-primary"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Books</div>
                        <div class="fs-3 fw-bold">@Model.TotalBooks</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-check-circle fs-3 text-success"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Available Books</div>
                        <div class="fs-3 fw-bold">@Model.AvailableBooks</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-arrow-left-right fs-3 text-warning"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Active Borrows</div>
                        <div class="fs-3 fw-bold">@Model.ActiveBorrows</div>
                    </div>
                </div>
            </div>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-people fs-3 text-info"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Total Users</div>
                            <div class="fs-3 fw-bold">@Model.TotalUsers</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 fw-semibold pt-3">
                    <i class="bi bi-clock-history text-primary"></i> Recent Borrow Activity
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Book</th>
                                <th>Due Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.RecentBorrows)
                            {
                                <tr>
                                    <td>@b.User.FullName</td>
                                    <td>@b.Book.Title</td>
                                    <td>@b.DueDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (b.IsReturned)
                                        {
                                            <span class="badge bg-success">Returned</span>
                                        }
                                        else if (b.DueDate < DateTime.Now)
                                        {
                                            <span class="badge bg-danger">Overdue</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Borrowed</span>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!Model.RecentBorrows.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">
                                        No activity yet.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 fw-semibold pt-3">
                    <i class="bi bi-exclamation-triangle text-danger"></i> Overdue Books
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Book</th>
                                <th>Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.OverdueBorrows)
                            {
                                <tr>
                                    <td>@b.User.FullName</td>
                                    <td>@b.Book.Title</td>
                                    <td class="text-danger small">
                                        @b.DueDate.ToString("MMM dd")
                                    </td>
                                </tr>
                            }
                            @if (!Model.OverdueBorrows.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-3">
                                        No overdue books!
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}