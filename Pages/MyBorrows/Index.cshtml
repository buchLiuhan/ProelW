@page
@model LibraryManagementSystem.Pages.MyBorrows.IndexModel
@{
    ViewData["Title"] = "My Borrowed Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bookmark-check me-2"></i>My Borrowed Books</h4>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-book fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Currently Borrowed</div>
                    <div class="fs-4 fw-bold">@Model.ActiveCount</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-check-circle fs-3 text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Returned</div>
                    <div class="fs-4 fw-bold">@Model.ReturnedCount</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-exclamation-triangle fs-3 text-danger"></i>
                </div>
                <div>
                    <div class="text-muted small">Overdue</div>
                    <div class="fs-4 fw-bold">@Model.OverdueCount</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th class="ps-3">#</th>
                    <th>Book Title</th>
                    <th>Author</th>
                    <th>Borrowed On</th>
                    <th>Due Date</th>
                    <th>Returned On</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Records)
                {
                    <tr>
                        <td class="ps-3">@r.Id</td>
                        <td class="fw-semibold">@r.Book.Title</td>
                        <td class="text-muted">@r.Book.Author</td>
                        <td class="small">@r.BorrowedAt.ToString("MMM dd, yyyy")</td>
                        <td class="small @(r.DueDate < DateTime.Now && !r.IsReturned ? "text-danger fw-semibold" : "")">
                            @r.DueDate.ToString("MMM dd, yyyy")
                        </td>
                        <td class="small text-muted">
                            @(r.ReturnedAt.HasValue? r.ReturnedAt.Value.ToString("MMM dd, yyyy") : "—")
                        </td>
                        <td>
                            @if (r.IsReturned)
                            {
                                <span class="badge bg-success">Returned</span>
                            }
                            else if (r.DueDate < DateTime.Now)
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Borrowed</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Records.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            You have no borrow history yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>