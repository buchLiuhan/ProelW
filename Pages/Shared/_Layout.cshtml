<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Libman — @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @if (User.Identity!.IsAuthenticated)
    {
        <nav class="navbar navbar-expand-lg navbar-dark" id="mainNav">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold" href="/Dashboard">
                    <i class="bi bi-book-half me-2"></i>Lib<span class="brand-accent">man</span>
                </a>
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["Title"]?.ToString() == "Dashboard" ? "active" : "")"
                               href="/Dashboard">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewData["Title"]?.ToString() == "Books" ? "active" : "")"
                               href="/Books">
                                <i class="bi bi-journals me-1"></i>Books
                            </a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewData["Title"]?.ToString() == "Borrow Records" ? "active" : "")"
                                   href="/Borrows">
                                    <i class="bi bi-arrow-left-right me-1"></i>Borrows
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewData["Title"]?.ToString() == "My Borrowed Books" ? "active" : "")"
                                   href="/MyBorrows">
                                    <i class="bi bi-bookmark-check me-1"></i>My Borrows
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewData["Title"]?.ToString() == "Library Policy" ? "active" : "")"
                                   href="/Policy">
                                    <i class="bi bi-clipboard-check me-1"></i>Policy
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewData["Title"]?.ToString() == "User Management" ? "active" : "")"
                                   href="/Users">
                                    <i class="bi bi-people me-1"></i>Users
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                               href="#" data-bs-toggle="dropdown">
                                <div class="avatar-circle">
                                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                                </div>
                                <span class="d-none d-lg-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li>
                                    <div class="dropdown-item-text py-2">
                                        <div class="fw-semibold small">@User.Identity.Name</div>
                                        <div class="text-muted" style="font-size:0.75rem;">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <span class="badge bg-danger">Admin</span>
                                            }
                                            else if (User.IsInRole("Librarian"))
                                            {

                                                <span class="badge bg-primary">Librarian</span>
                                            }
                                            else
                                            {

                                                <span class="badge bg-secondary">Student</span>
                                            }
                                        </div>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider my-1" /></li>
                                <li>
                                    <a class="dropdown-item text-danger small" href="/Auth/Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <main class="main-content">
        <div class="container-fluid px-4 py-4">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>